  create view "data_warehouse"."public"."stg_campagne__dbt_tmp"
    
    
  as (
    WITH source AS (
    SELECT * FROM "data_warehouse"."public_raw"."raw_campagne"
),
renamed AS (
    SELECT
        -- Création d'une clé surrogate pour la ligne de fait
        md5(cast(coalesce(cast(id_campagne as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(date_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) AS campagne_key,
        CAST(id_parcelle AS INT) AS id_parcelle,
        CAST(id_produit AS INT) AS id_produit,
        CAST(id_meteo AS INT) AS id_meteo,
        CAST(date_id AS INT) AS date_id,
        
        -- Nettoyage des NA et Conversion
        CAST(NULLIF(tonnage_recolte, 'NA') AS FLOAT) AS tonnage_recolte,
        CAST(NULLIF(tonnage_exporte, 'NA') AS FLOAT) AS tonnage_exporte,
        CAST(NULLIF(cout_intrants_devise, 'NA') AS FLOAT) AS cout_intrants_devise,
        devise_origine
    FROM source
    WHERE id_campagne IS NOT NULL -- Suppression des lignes vides
)
SELECT DISTINCT * FROM renamed -- Suppression des doublons
  );
