  create view "data_warehouse"."public"."fct_campagne_performances__dbt_tmp"
    
    
  as (
    WITH stg_campagne AS (
    SELECT * FROM "data_warehouse"."public"."stg_campagne"
),
stg_parcelles AS (
    SELECT * FROM "data_warehouse"."public"."stg_parcelles"
),
-- Ajout de la logique de conversion
conversion AS (
    SELECT 
        *,
        CASE 
            WHEN devise_origine = 'EUR' THEN cout_intrants_devise * 655.95
            WHEN devise_origine = 'USD' THEN cout_intrants_devise * 600
            ELSE cout_intrants_devise 
        END AS cout_intrants_fcfa
    FROM stg_campagne
)

SELECT
    c.campagne_key,
    c.date_id,
    c.id_produit,
    p.localisation,
    p.surface_hectares,
    c.tonnage_recolte,
    c.tonnage_exporte,
    -- Calcul du gaspillage
    (COALESCE(c.tonnage_recolte, 0) - COALESCE(c.tonnage_exporte, 0)) AS tonnage_perdu,
    -- Rendement
    SAFE_DIVIDE(c.tonnage_recolte, p.surface_hectares) AS rendement_ha,
    -- Finance en FCFA
    c.cout_intrants_fcfa
FROM conversion c
LEFT JOIN stg_parcelles p ON c.id_parcelle = p.id_parcelle
  );
